# Choose one provider: gemini, azure, or openai
SAFETRIP_MODEL_PROVIDER=gemini

# Optional global fallback model. Per-agent settings below take priority.
# SAFETRIP_MODEL=gemini-2.5-flash

# Per-agent model overrides (provider-specific names). Leave unset to use the
# tier defaults below. Tiers are: orchestrator/perception/intake/evidence/
# guidance/synthesis = low; completeness/drafting/safety = high.
# SAFETRIP_ORCHESTRATOR_MODEL=
# SAFETRIP_PERCEPTION_MODEL=
# SAFETRIP_COMPLETENESS_MODEL=
# SAFETRIP_GUIDANCE_MODEL=
# SAFETRIP_DRAFTING_MODEL=
# SAFETRIP_SYNTHESIS_MODEL=
# SAFETRIP_SAFETY_MODEL=

# --- Gemini ---
# Tier defaults: low=gemini-2.5-flash, high=gemini-2.5-pro
GEMINI_API_KEY=replace_with_your_gemini_key

# --- Azure AI Foundry (Azure OpenAI deployments) ---
# SAFETRIP_MODEL_PROVIDER=azure
# AZURE_OPENAI_ENDPOINT=https://<your-foundry-resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=replace_with_your_azure_openai_key
# AZURE_OPENAI_API_VERSION=2024-10-21
# Deployment names you created in Foundry. Defaults: gpt-5-mini / gpt-5.
# SAFETRIP_AZURE_LOW_DEPLOYMENT=gpt-5-mini
# SAFETRIP_AZURE_HIGH_DEPLOYMENT=gpt-5

# --- OpenAI ---
# SAFETRIP_MODEL_PROVIDER=openai
# OPENAI_API_KEY=replace_with_your_openai_key
