# Choose one provider: openai or gemini
SAFETRIP_MODEL_PROVIDER=gemini

# Optional global fallback model. Per-agent settings below take priority.
# SAFETRIP_MODEL=gemini-2.5-flash

# Per-agent Gemini models. Tune cost/latency/quality by workload.
SAFETRIP_ORCHESTRATOR_MODEL=gemini-2.5-flash
SAFETRIP_INTAKE_MODEL=gemini-2.5-flash
SAFETRIP_EVIDENCE_MODEL=gemini-2.5-flash
SAFETRIP_COMPLETENESS_MODEL=gemini-2.5-pro
SAFETRIP_GUIDANCE_MODEL=gemini-2.5-flash
SAFETRIP_DRAFTING_MODEL=gemini-2.5-pro
SAFETRIP_SAFETY_MODEL=gemini-2.5-pro

# Keep real API keys out of git.
GEMINI_API_KEY=replace_with_your_gemini_key

# OpenAI alternative:
# SAFETRIP_MODEL_PROVIDER=openai
# SAFETRIP_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=replace_with_your_openai_key
